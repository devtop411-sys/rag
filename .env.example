PORT=3001

VOYAGE_API_KEY=your_voyage_api_key
VOYAGE_MODEL=voyage-3.5

# ---------------------------------------------------------------------------
# AWS S3 — required for file storage
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=investment_memos

# Optional — set a shared secret to protect the API endpoints.
# Must be the same value as VITE_API_KEY in the frontend .env.
API_KEY=

# Frontend (Vite) — must match API_KEY above so the browser sends the header.
VITE_API_KEY=

# ---------------------------------------------------------------------------
# MCP server (Streamable HTTP transport, exposed at /mcp)
# Secured with OAuth 2.1 + PKCE. Clients (e.g. claude.ai Custom Connectors)
# must complete a Google sign-in before they can call any tool.
# ---------------------------------------------------------------------------
MCP_PORT=3002

# Public origin of this server, used in OAuth metadata and token audiences.
# MUST be set in production so token issuer/audience are stable behind proxies.
# e.g. https://rag.collider.vc
PUBLIC_BASE_URL=

# Secret used to sign MCP access/refresh tokens (JWT HS256). REQUIRED in
# production — if unset, an ephemeral key is generated and tokens are invalidated
# on every restart and won't validate across multiple instances.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
OAUTH_SIGNING_SECRET=

# Token lifetimes in seconds (optional). Defaults: 1h access, 30d refresh.
OAUTH_ACCESS_TTL=3600
OAUTH_REFRESH_TTL=2592000

# Extra allowed OAuth redirect URIs (comma-separated). claude.ai / claude.com
# callbacks and localhost are always allowed; add others only if needed.
OAUTH_EXTRA_REDIRECT_URIS=

# ---------------------------------------------------------------------------
# Meta-query tagging (optional)
# When set, each ingested chunk is labelled with financial topic tags via LLM.
# Any OpenAI-compatible endpoint works (OpenAI, Azure, local Ollama, etc.).
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Slack bot + Dify
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
DIFY_API_KEY=
DIFY_URL=http://34.245.224.130/v1/chat-messages

# ---------------------------------------------------------------------------
# Google OAuth — restrict login to @collider.vc accounts
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised JavaScript origins: https://your-domain.com
#   (MUST include PUBLIC_BASE_URL — the MCP sign-in page renders the Google
#    button on this server's own domain.)
# Authorised redirect URIs: not needed (Google Identity Services token flow)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
